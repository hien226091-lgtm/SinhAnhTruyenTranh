# ========================================
# AuraComic Studio - Environment Variables
# Copy this file to .env and fill values
# ========================================

# --- Google Cloud / Vertex AI ---
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_TEXT_MODEL=gemini-2.5-pro
VERTEX_IMAGE_MODELS=imagen-4.0-generate-001

# Path to GCP service account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\key.json

# Fallback: Google AI Studio API key (if not using Vertex)
# GEMINI_API_KEY=your-gemini-api-key
# GOOGLE_AI_API_KEY=your-google-ai-key

# --- Database ---
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/truyentranh_ai?charset=utf8mb4

# --- JWT Authentication ---
# Generate a strong random secret (e.g. python -c "import os; print(os.urandom(32).hex())")
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
PASSWORD_SALT=change-me-to-a-random-salt

# --- Admin Account ---
ADMIN_USERNAME=admin
# PBKDF2 hash of admin password
ADMIN_PASSWORD_HASH=

# --- OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
OAUTH_REDIRECT_BASE=http://localhost:8000

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
